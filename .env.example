# ── LLM Provider ─────────────────────────────────────────────
# Opções: "bedrock" (padrão) | "openai"
LLM_PROVIDER=bedrock

# Amazon Bedrock (usado quando LLM_PROVIDER=bedrock)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
# Modelos alternativos:
# BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# OpenAI (usado quando LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Pipeline ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///earnings.db
LLM_TEMPERATURE=0
MAX_RETRIES=2
MIN_COMPLETUDE_CORE=0.8
REVIEW_QUEUE_PATH=review_queue/
OUTPUT_PATH=output/
